---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";
import { getCollection } from "astro:content";
import { BASE } from "../../lib/site";

const allNotes = (await getCollection("notes"))
  .filter((n) => !n.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// 按主题分组
const topics = [...new Set(allNotes.map((n) => n.data.topic))];
---

<BaseLayout title="学习笔记" description="学习笔记列表">
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-2">
      学习笔记
    </h1>
    <p class="text-gray-500 dark:text-gray-400 mb-10">
      共 {allNotes.length} 篇笔记
    </p>

    {allNotes.length > 0 ? (
      topics.map((topic) => {
        const topicNotes = allNotes.filter((n) => n.data.topic === topic);
        return (
          <section class="mb-12">
            <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200 mb-4 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-green-500"></span>
              {topic}
            </h2>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {topicNotes.map((n) => (
                <Card entry={n} type="notes" href={`${BASE}/notes/${n.slug}`} />
              ))}
            </div>
          </section>
        );
      })
    ) : (
      <div class="py-20 text-center text-gray-400">
        <p>还没有学习笔记，快来记录吧！</p>
      </div>
    )}
  </section>
</BaseLayout>
