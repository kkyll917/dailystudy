---
import { BASE } from "../lib/site";
---

<footer class="border-t border-gray-200 dark:border-gray-800 mt-auto">
  <div class="max-w-5xl mx-auto px-4 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500 dark:text-gray-400">
      <p>&copy; {new Date().getFullYear()} MyWeb — Built with Astro</p>
      <div class="flex items-center gap-4">
        <a
          href={`${BASE}/blog`}
          class="hover:text-gray-900 dark:hover:text-white transition-colors"
        >
          博客
        </a>
        <a
          href={`${BASE}/notes`}
          class="hover:text-gray-900 dark:hover:text-white transition-colors"
        >
          学习笔记
        </a>
        <a
          href={`${BASE}/algorithms`}
          class="hover:text-gray-900 dark:hover:text-white transition-colors"
        >
          算法
        </a>
      </div>
    </div>
  </div>
</footer>
