---
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../lib/utils";
import { BASE } from "../lib/site";

export interface Props {
  entry: CollectionEntry<"blog" | "notes" | "algorithms">;
  type?: "blog" | "notes" | "algorithms";
}

const { entry, type } = Astro.props;
const { title, description, date } = entry.data;

const typeLabel = {
  blog: "博客",
  notes: "学习笔记",
  algorithms: "算法笔记",
}[type || "blog"];

const typePath = {
  blog: `${BASE}/blog`,
  notes: `${BASE}/notes`,
  algorithms: `${BASE}/algorithms`,
}[type || "blog"];
---

<BaseLayout title={title} description={description}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <!-- 面包屑 -->
    <nav class="text-sm text-gray-500 dark:text-gray-400 mb-8">
      <a href={`${BASE}/`} class="hover:text-blue-600 dark:hover:text-blue-400">首页</a>
      <span class="mx-2">/</span>
      <a href={typePath} class="hover:text-blue-600 dark:hover:text-blue-400">{typeLabel}</a>
      <span class="mx-2">/</span>
      <span>{title}</span>
    </nav>

    <!-- 标题区 -->
    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        {title}
      </h1>
      {
        description && (
          <p class="text-lg text-gray-500 dark:text-gray-400 mb-4">{description}</p>
        )
      }
      <div class="flex items-center gap-4 text-sm text-gray-400 dark:text-gray-500">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        {
          type === "notes" && "topic" in entry.data && (
            <span class="px-2 py-0.5 bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 rounded">
              {entry.data.topic as string}
            </span>
          )
        }
        {
          type === "algorithms" && "category" in entry.data && (
            <>
              <span class="px-2 py-0.5 bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 rounded">
                {entry.data.category as string}
              </span>
              <span class="px-2 py-0.5 bg-orange-100 dark:bg-orange-900 text-orange-700 dark:text-orange-300 rounded">
                {entry.data.difficulty as string}
              </span>
            </>
          )
        }
      </div>
      {
        "tags" in entry.data && entry.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-3">
            {(entry.data.tags as string[]).map((tag) => (
              <span class="px-2 py-0.5 text-xs bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded-full">
                #{tag}
              </span>
            ))}
          </div>
        )
      }
    </header>

    <!-- 正文 -->
    <div class="prose-custom">
      <slot />
    </div>
  </article>
</BaseLayout>
